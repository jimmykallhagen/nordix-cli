launch_program() {
    # save aktive state
    ORIG_GOVERNOR=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor)
    ORIG_EPP=$(cat /sys/devices/system/cpu/cpu0/cpufreq/energy_performance_preference 2>/dev/null || echo "none")
    
    # Cleanup function
    cleanup() {
        echo -e "${WHITE}Restoring system...${NC}"
        sudo sysctl -w vm.nr_hugepages=0 > /dev/null
        sudo cpupower frequency-set -g "$ORIG_GOVERNOR" > /dev/null
        if [ "$ORIG_EPP" != "none" ]; then
            echo "$ORIG_EPP" | sudo tee /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference > /dev/null
        fi
        echo -e "${GREEN}System restored${NC}"
    }
    
    # Trap for cleanup on exit/interrupt
    trap cleanup EXIT
    
    # performance mode
    sudo sysctl -w vm.nr_hugepages=${HUGEPAGES}
    sudo cpupower frequency-set -g performance
    echo performance | sudo tee /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference > /dev/null
    
    # Kör programmet (UTAN exec)
    $PROGRAM
    

}

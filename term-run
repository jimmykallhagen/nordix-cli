#!/bin/bash

# term-run - Auto-detects and runs terminal commands
# With fallback to $TERMINAL environment variable

TERM_CMD="$1"

if [ -z "$TERM_CMD" ]; then
    echo "Usage: term-run <command>"
    echo "Example: term-run 'htop'"
    exit 1
fi

# List of terminals in preferred order
TERMINALS=("cosmic-term" "alacritty" "kitty" "foot" "gnome-terminal" "konsole" "xterm" "urxvt")

# Function to run command in terminal
run_in_terminal() {
    local term="$1"
    local cmd="$2"
    
    case "$term" in
        "cosmic-term")
            exec cosmic-term -e sh -c "$cmd"
            ;;
        "alacritty")
            exec alacritty -e sh -c "$cmd"
            ;;
        "kitty")
            exec kitty sh -c "$cmd"
            ;;
        "foot")
            exec foot sh -c "$cmd"
            ;;
        "gnome-terminal")
            exec gnome-terminal -- sh -c "$cmd"
            ;;
        "konsole")
            exec konsole -e sh -c "$cmd"
            ;;
        "xterm")
            exec xterm -e sh -c "$cmd"
            ;;
        "urxvt"|"rxvt-unicode")
            exec urxvt -e sh -c "$cmd"
            ;;
        *)
            # Generic fallback
            exec "$term" -e sh -c "$cmd"
            ;;
    esac
}

# Try terminals in order
for term in "${TERMINALS[@]}"; do
    if command -v "$term" >/dev/null 2>&1; then
        run_in_terminal "$term" "$TERM_CMD"
    fi
done

# Try $TERMINAL environment variable as last resort
if [ -n "$TERMINAL" ] && command -v "$TERMINAL" >/dev/null 2>&1; then
    run_in_terminal "$TERMINAL" "$TERM_CMD"
fi

# No terminal found
echo "Error: No terminal found!"
echo "Please install one of: ${TERMINALS[*]}"
exit 1

save_state() {
    # Save current CPU governor
    ORIG_GOVERNOR=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "schedutil")
    
    # Save current energy performance preference
    ORIG_EPP=$(cat /sys/devices/system/cpu/cpu0/cpufreq/energy_performance_preference 2>/dev/null || echo "balance_performance")
    
    # Save current hugepages
    ORIG_HUGEPAGES=$(cat /proc/sys/vm/nr_hugepages 2>/dev/null || echo "0")
}

restore_state() {
    echo ""
    draw_border
    echo -e "${WHITE}Restoring system state...${NC}"
    draw_border
    echo ""
    
    # Restore hugepages
    sudo sysctl -w vm.nr_hugepages="$ORIG_HUGEPAGES" > /dev/null 2>&1
    echo -e "${NARTIC}HugePages restored to: ${NHYPRBLUE}${ORIG_HUGEPAGES}${NC}"
    
    # Restore CPU governor
    sudo cpupower frequency-set -g "$ORIG_GOVERNOR" > /dev/null 2>&1
    echo -e "${NARTIC}CPU governor restored to: ${NHYPRBLUE}${ORIG_GOVERNOR}${NC}"
    
    # Restore energy performance preference
    if [ -f /sys/devices/system/cpu/cpu0/cpufreq/energy_performance_preference ]; then
        echo "$ORIG_EPP" | sudo tee /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference > /dev/null 2>&1
        echo -e "${NARTIC}Energy preference restored to: ${NHYPRBLUE}${ORIG_EPP}${NC}"
    fi
    
    echo ""
    draw_border
    echo -e "${GREEN}System restored successfully${NC}"
    draw_border
    echo ""
    echo -e "${NVFROST}Hope you enjoyed Nordix Performance Launcher!${NC}"
    echo ""
    sleep 2
}

launch_program() {
    # Save current state before making changes
    save_state
    
    # Set up trap to restore state on exit/interrupt
    trap restore_state EXIT
    
    echo ""
    draw_border
    echo -e "${WHITE}Applying performance settings...${NC}"
    draw_border
    echo ""
    
    # Set hugepages
    sudo sysctl -w vm.nr_hugepages=${HUGEPAGES} > /dev/null 2>&1
    echo -e "${NARTIC}HugePages set to: ${NHYPRBLUE}${HUGEPAGES} (${RAM})${NC}"
    
    # Set CPU governor to performance
    sudo cpupower frequency-set -g performance > /dev/null 2>&1
    echo -e "${NARTIC}CPU governor set to: ${NHYPRBLUE}performance${NC}"
    
    # Set energy performance preference to performance
    if [ -f /sys/devices/system/cpu/cpu0/cpufreq/energy_performance_preference ]; then
        echo performance | sudo tee /sys/devices/system/cpu/cpu*/cpufreq/energy_performance_preference > /dev/null 2>&1
        echo -e "${NARTIC}Energy preference set to: ${NHYPRBLUE}performance${NC}"
    fi
    
    # Disable USB power saving
    for usb in /sys/bus/usb/devices/*/power/control; do
        if [ -f "$usb" ]; then
            echo "on" | sudo tee "$usb" > /dev/null 2>&1
        fi
    done
    echo -e "${NARTIC}USB power saving: ${NHYPRBLUE}disabled${NC}"
    
    echo ""
    draw_border
    echo -e "${GREEN}Launching: ${PROGRAM}${NC}"
    draw_border
    echo ""
    
    sleep 1
    
    # Hide terminal (swallow) using Hyprland
    hyprctl dispatch movetoworkspacesilent special:hidden,pid:$TERMINAL_PID 2>/dev/null
    
    # Check if this is a VM manager that spawns QEMU processes
    IS_VM_MANAGER=false
    case "$PROGRAM" in
        *virt-manager*|*gnome-boxes*|*virtmanager*)
            IS_VM_MANAGER=true
            echo -e "${NARTIC}VM Manager detected - will wait for all VMs to close${NC}"
            ;;
    esac
    
    # Run the program (NOT exec, so script continues after)
    $PROGRAM &
    PROGRAM_PID=$!
    
    if [ "$IS_VM_MANAGER" = true ]; then
        # Wait for virt-manager to start
        sleep 2
        
        # Wait for virt-manager AND all QEMU processes to finish
        while true; do
            # Check if virt-manager is still running
            VM_MANAGER_RUNNING=false
            if kill -0 $PROGRAM_PID 2>/dev/null; then
                VM_MANAGER_RUNNING=true
            fi
            
            # Check if any QEMU processes are running
            QEMU_RUNNING=false
            if pgrep -x "qemu-system-x86_64" > /dev/null 2>&1 || \
               pgrep -x "qemu-system-x86" > /dev/null 2>&1 || \
               pgrep -x "qemu-kvm" > /dev/null 2>&1 || \
               pgrep -f "qemu-system" > /dev/null 2>&1; then
                QEMU_RUNNING=true
            fi
            
            # Exit loop only when both virt-manager AND all VMs are closed
            if [ "$VM_MANAGER_RUNNING" = false ] && [ "$QEMU_RUNNING" = false ]; then
                break
            fi
            
            sleep 2
        done
    else
        # For non-VM-manager programs, just wait normally
        wait $PROGRAM_PID
    fi
    
    # Bring terminal back
    hyprctl dispatch movetoworkspace e+0,pid:$TERMINAL_PID 2>/dev/null
    
    # restore_state will be called automatically via trap EXIT
}

# ============================================
# MAIN LOOP
# ============================================
while true; do
    show_menu
    echo ""
    echo -e "${WHITE}Enter your choice (0-9):${NC}"
    echo -ne "${NHYPRBLUE}❯ ${NC}"
    read choice
    
    case $choice in
        1) 
            HUGEPAGES=512
            RAM="1GB"
            launch_program
            exit 0
            ;;
        2) 
            HUGEPAGES=1024 
            RAM="2GB" 
            launch_program
            exit 0
            ;;
        3)
            HUGEPAGES=2048        
            RAM="4GB"
            launch_program
            exit 0
            ;;
        4)
            HUGEPAGES=4096 
            RAM="8GB"
            launch_program
            exit 0
            ;;
        5)
            HUGEPAGES=6144 
            RAM="12GB"
            launch_program
            exit 0
            ;;
        6)
            HUGEPAGES=8192 
            RAM="16GB"
            launch_program
            exit 0
            ;;
        7)
            HUGEPAGES=10240 

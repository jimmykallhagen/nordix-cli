    echo -e "${BLUE} 2${NC} ${NVFROST}-${NC} ${NARTIC}HUGEPAGES=1024  ${NHYPRBLUE}(2GB RAM)${NC}"
    echo -e "${BLUE} 3${NC} ${NVFROST}-${NC} ${NARTIC}HUGEPAGES=2048  ${NHYPRBLUE}(4GB RAM)${NC}"
